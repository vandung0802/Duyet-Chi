{
  "rules": {

    "duyetchi": {
      // v79 BẢO MẬT: KHÔNG đặt ".read" ở cấp cha này. Trong Firebase RTDB, ".read" ở cha LAN XUỐNG mọi
      // con và con KHÔNG thu hồi được — nếu để ".read: auth != null" ở đây thì pendingOtp (mã OTP) sẽ bị
      // MỌI tài khoản đọc được, vô hiệu hoá luật đọc-hạn-chế của nó. Vì vậy quyền đọc được khai riêng ở
      // TỪNG nhánh con bên dưới (proposals/images/plans/meta/userRoles/online đều cho người đăng nhập đọc;
      // riêng pendingOtp chỉ chính chủ hoặc Dũng đọc).

      "userRoles": {
        // v81: Dũng đọc được CẢ node (để hiện danh sách "duyệt tài khoản"). Người khác chỉ đọc bản thân (ở $uid).
        ".read": "auth != null && root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung'",
        "$uid": {
          ".read": "auth != null",
          // CHẶN LEO QUYỀN (v77): tự ghi role của MÌNH chỉ được 'other' — TRỪ 3 người nhà xác thực
          // bằng ĐÚNG EMAIL đăng nhập (không thể giả). Dũng ghi được cho bất kỳ ai.
          // v81/v82: TỰ ghi được hồ sơ của mình (tên/email/lastLogin) nhưng KHÔNG được TỰ ĐỔI cờ approved
          // (phải giữ nguyên như cũ) — chống tự cấp quyền xem. Chỉ Dũng mới đặt/đổi approved.
          ".write": "auth != null && ((auth.uid === $uid && newData.child('approved').val() === data.child('approved').val() && (newData.child('role').val() === 'other' || (newData.child('role').val() === 'dung' && auth.token.email === 'vandung0802@gmail.com') || (newData.child('role').val() === 'hien' && auth.token.email === 'hiensbgt@gmail.com') || (newData.child('role').val() === 'trang' && auth.token.email === 'phantrang770@gmail.com'))) || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung')"
        }
      },

      "meta": {
        // v81: chỉ tài khoản ĐÃ ĐƯỢC DUYỆT (approved) hoặc 3 email người nhà mới đọc được.
        ".read": "auth != null && (root.child('duyetchi/userRoles').child(auth.uid).child('approved').val() === true || auth.token.email === 'vandung0802@gmail.com' || auth.token.email === 'hiensbgt@gmail.com' || auth.token.email === 'phantrang770@gmail.com')",
        // Chỉ Dũng mới sửa được danh sách người/công trình
        ".write": "auth != null && root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung'"
      },

      "proposals": {
        // v81: chỉ tài khoản ĐÃ ĐƯỢC DUYỆT hoặc 3 email người nhà mới đọc được (chống người lạ tự đăng ký xem).
        ".read": "auth != null && (root.child('duyetchi/userRoles').child(auth.uid).child('approved').val() === true || auth.token.email === 'vandung0802@gmail.com' || auth.token.email === 'hiensbgt@gmail.com' || auth.token.email === 'phantrang770@gmail.com')",
        "$id": {
          // Tạo/sửa: phải là tài khoản ĐÃ DUYỆT (v83 — tài khoản lạ/đã thu hồi không tạo/sửa phiếu được);
          // chi tiết bị siết thêm bằng validate từng trường bên dưới.
          // XÓA CẢ PHIẾU (newData không tồn tại): phiếu ĐÃ có duyệt → chỉ Dũng; phiếu chưa duyệt → tài khoản đã duyệt.
          ".write": "auth != null && (root.child('duyetchi/userRoles').child(auth.uid).child('approved').val() === true || auth.token.email === 'vandung0802@gmail.com' || auth.token.email === 'hiensbgt@gmail.com' || auth.token.email === 'phantrang770@gmail.com') && (newData.exists() || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung' || !(data.child('approvedD').exists() || data.child('approvedH').exists() || data.child('approvedDHistory').exists() || data.child('approvedHHistory').exists()))",

          // CHẶN GỠ DẤU DUYỆT / GỠ LỊCH SỬ (duyệt+chuyển) / GỠ ẢNH NỘI DUNG (v77 + v80):
          // - gỡ approvedD chỉ Dũng; gỡ approvedH chỉ Hiền (bỏ duyệt hợp lệ) — kẻ khác không thể "tự bỏ duyệt để mở khóa sửa"
          // - gỡ cả node transfers chỉ Trang; gỡ approvedDHistory chỉ Dũng, approvedHHistory chỉ Hiền (v80 —
          //   chống xóa/null lịch sử rồi lợi dụng approvedDAmount phụ để "backfill" số tiền giả)
          // - gỡ contentSnapshot (ảnh nội dung lúc duyệt) chỉ Dũng/Hiền
          ".validate": "(newData.child('approvedD').exists() || !data.child('approvedD').exists() || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung') && (newData.child('approvedH').exists() || !data.child('approvedH').exists() || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'hien') && (newData.child('transfers').exists() || !data.child('transfers').exists() || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'trang') && (newData.child('approvedDHistory').exists() || !data.child('approvedDHistory').exists() || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung') && (newData.child('approvedHHistory').exists() || !data.child('approvedHHistory').exists() || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'hien') && (newData.child('contentSnapshot').exists() || !data.child('contentSnapshot').exists() || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung' || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'hien')",

          // ĐÓNG BĂNG NỘI DUNG sau khi D HOẶC H đã duyệt (v77 — chống sửa số tài khoản/số tiền sau duyệt):
          // các trường dưới đây chỉ được GIỮ NGUYÊN một khi phiếu đã có bất kỳ dấu duyệt nào.
          // Muốn sửa thật: D/H bỏ duyệt trước (được phép theo luật trên) → sửa → duyệt lại.
          "desc":       { ".validate": "newData.val() === data.val() || !(data.parent().child('approvedD').exists() || data.parent().child('approvedH').exists() || data.parent().child('approvedDHistory').exists() || data.parent().child('approvedHHistory').exists())" },
          "note":       { ".validate": "newData.val() === data.val() || !(data.parent().child('approvedD').exists() || data.parent().child('approvedH').exists() || data.parent().child('approvedDHistory').exists() || data.parent().child('approvedHHistory').exists())" },
          "amount":     { ".validate": "newData.val() === data.val() || !(data.parent().child('approvedD').exists() || data.parent().child('approvedH').exists() || data.parent().child('approvedDHistory').exists() || data.parent().child('approvedHHistory').exists())" },
          "amountUnit": { ".validate": "newData.val() === data.val() || !(data.parent().child('approvedD').exists() || data.parent().child('approvedH').exists() || data.parent().child('approvedDHistory').exists() || data.parent().child('approvedHHistory').exists())" },
          "person":     { ".validate": "newData.val() === data.val() || !(data.parent().child('approvedD').exists() || data.parent().child('approvedH').exists() || data.parent().child('approvedDHistory').exists() || data.parent().child('approvedHHistory').exists())" },
          "site":       { ".validate": "newData.val() === data.val() || !(data.parent().child('approvedD').exists() || data.parent().child('approvedH').exists() || data.parent().child('approvedDHistory').exists() || data.parent().child('approvedHHistory').exists())" },

          // DẤU DUYỆT: thêm/đổi approvedD chỉ Dũng, approvedH chỉ Hiền (giữ nguyên thì ai ghi cũng được —
          // cần thiết vì app luôn ghi CẢ phiếu mỗi lần có gì đổi, các trường không đổi phải đi qua được)
          "approvedD": { ".validate": "(data.exists() && newData.val() === data.val()) || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung'" },
          "approvedH": { ".validate": "(data.exists() && newData.val() === data.val()) || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'hien'" },

          // BẢN LƯU PHỤ số tiền duyệt (approvedDAmount/HAmount): đổi giá trị chỉ Dũng/Hiền (v80).
          // Trước đây 2 trường này KHÔNG bị khóa → kẻ xấu đặt số giả rồi để máy D/H "backfill" thành lịch sử.
          "approvedDAmount": { ".validate": "(data.exists() && newData.val() === data.val()) || !newData.exists() || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung'" },
          "approvedHAmount": { ".validate": "(data.exists() && newData.val() === data.val()) || !newData.exists() || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'hien'" },

          // LỊCH SỬ DUYỆT (nguồn chuẩn số tiền): từng lần duyệt BẤT BIẾN sau khi ghi; THÊM lần mới chỉ đúng người
          "approvedDHistory": { "$i": { ".validate": "(data.exists() && newData.child('amount').val() === data.child('amount').val() && newData.child('ts').val() === data.child('ts').val()) || (!data.exists() && root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung')" } },
          "approvedHHistory": { "$i": { ".validate": "(data.exists() && newData.child('amount').val() === data.child('amount').val() && newData.child('ts').val() === data.child('ts').val()) || (!data.exists() && root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'hien')" } },

          // LỊCH SỬ CHUYỂN TIỀN: từng lần chuyển bất biến; thêm lần mới chỉ Trang
          "transfers": { "$i": { ".validate": "(data.exists() && newData.child('amount').val() === data.child('amount').val() && newData.child('ts').val() === data.child('ts').val()) || (!data.exists() && root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'trang')" } },

          // TRẠNG THÁI: đặt lần đầu (tạo phiếu) ai cũng được; ĐỔI về sau chỉ Dũng/Hiền/Trang (chặn vai trò 'other' giả mạo "đã chuyển")
          "status": { ".validate": "!data.exists() || newData.val() === data.val() || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung' || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'hien' || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'trang'" },

          // ẢNH NỘI DUNG LÚC DUYỆT (contentSnapshot — lớp phát hiện): từng trường chỉ Dũng/Hiền ghi/đổi
          "contentSnapshot": { "$f": { ".validate": "(data.exists() && newData.val() === data.val()) || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung' || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'hien'" } }
        }
      },

      "images": {
        // v81: chỉ tài khoản ĐÃ ĐƯỢC DUYỆT hoặc 3 email người nhà mới đọc được.
        ".read": "auth != null && (root.child('duyetchi/userRoles').child(auth.uid).child('approved').val() === true || auth.token.email === 'vandung0802@gmail.com' || auth.token.email === 'hiensbgt@gmail.com' || auth.token.email === 'phantrang770@gmail.com')",
        "$id": {
          // v83: GHI cũng phải là tài khoản ĐÃ DUYỆT (tài khoản lạ / đã bị thu hồi không ghi/xoá ảnh được).
          ".write": "auth != null && (root.child('duyetchi/userRoles').child(auth.uid).child('approved').val() === true || auth.token.email === 'vandung0802@gmail.com' || auth.token.email === 'hiensbgt@gmail.com' || auth.token.email === 'phantrang770@gmail.com')"
        }
      },

      "plans": {
        // v81: chỉ tài khoản ĐÃ ĐƯỢC DUYỆT hoặc 3 email người nhà mới đọc được.
        ".read": "auth != null && (root.child('duyetchi/userRoles').child(auth.uid).child('approved').val() === true || auth.token.email === 'vandung0802@gmail.com' || auth.token.email === 'hiensbgt@gmail.com' || auth.token.email === 'phantrang770@gmail.com')",
        "$id": {
          // v83: GHI cũng phải là tài khoản ĐÃ DUYỆT.
          ".write": "auth != null && (root.child('duyetchi/userRoles').child(auth.uid).child('approved').val() === true || auth.token.email === 'vandung0802@gmail.com' || auth.token.email === 'hiensbgt@gmail.com' || auth.token.email === 'phantrang770@gmail.com')"
        }
      },

      "pendingOtp": {
        "$uid": {
          // Chỉ chính mình hoặc Dũng đọc/xóa OTP
          ".read": "auth != null && (auth.uid === $uid || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung')",
          ".write": "auth != null && (auth.uid === $uid || root.child('duyetchi/userRoles').child(auth.uid).child('role').val() === 'dung')"
        }
      },

      "online": {
        ".read": "auth != null",
        "$uid": {
          // Chỉ chính mình ghi trạng thái online của mình
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },

    "push-subs": {
      // v80 BẢO MẬT: subscription nhóm theo VAI TRÒ (push-subs/{role}/{token}). Trước đây mọi tài khoản
      // ghi được vào bất kỳ vai trò → kẻ xấu đăng ký dưới 'dung' để NHẬN thông báo của Dũng (gồm cả mã
      // OTP gửi qua push). Nay chỉ được ghi vào ĐÚNG vai trò server xác nhận của mình.
      "$role": {
        ".read": false,
        // v83: thêm điều kiện ĐÃ DUYỆT (tài khoản đã thu hồi không đăng ký nhận push nữa).
        ".write": "auth != null && $role === root.child('duyetchi/userRoles').child(auth.uid).child('role').val() && (root.child('duyetchi/userRoles').child(auth.uid).child('approved').val() === true || auth.token.email === 'vandung0802@gmail.com' || auth.token.email === 'hiensbgt@gmail.com' || auth.token.email === 'phantrang770@gmail.com')"
      }
    },

    "push-queue": {
      // v83: GIỮ cho mọi tài khoản đăng nhập gửi được — vì lúc ĐĂNG KÝ (chưa duyệt) app phải gửi push
      // báo mã OTP cho Dũng. Khóa theo approved sẽ hỏng luồng đăng ký. Rủi ro spam thông báo là nhỏ,
      // Cloud Function nhận push có thể tự lọc thêm nếu cần.
      ".read": false,
      ".write": "auth != null"
    }
  }
}
